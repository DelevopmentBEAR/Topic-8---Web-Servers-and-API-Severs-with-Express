<!-- Div class with background color for header, margin, padding and centering the text -->
    <div class="header bg-primary-subtle mb-3 p-2 rounded-3 text-center">
        <!-- Student Feedback Form header -->
        <h1>Please provide feedback. You may do so anonymously.</h1>
    </div> <!-- End of header div -->
    <!-- Row div for Bootstrap grid system -->
     <div class="row">
        <!-- Instructions div -->
        <div class="intro col-md-5 sm-12">
            <h2>Instructions</h2>

            <p>As one of our students, your thoughts, feedback, and comments are important to us.</p>
            <p>Please take a moment to share your comments with us.</p>
            <p>If you would like us to follow up with you, please include your email address.</p>
        </div> <!-- End of Instructions div -->
        <!-- Form div -->
         <div class="col-md-7 sm-12">
            <!-- form wrapper with reroute to /submit-feedback with post -->
            <form action="/submit-feedback" method="post">
                <!-- Label for student name-->
                <label class="form-label" for="name">Name:</label>
                <!-- Input type text, optional  -->
                <input class="form-control" type="text" id="student-name" name="name">
                <!-- Breaks for webpage spacing -->
                <br> 
                <!-- Label for student email -->
                <label class="form-label" for="email">Email:</label>
                <!-- Input type email, optional -->
                <input class="form-control" type="email" id="student-email" name="email">
                <br>
                <!-- Label for student's comments -->
                <label class="form-label" for="comments">Comments:</label>
                <br>
                <!-- Text area for student comments, required -->
                <textarea class="form-control" id="comments" name="comments" required></textarea>
                <br>
                <!-- P element question for current student radio buttons -->
                <p class="mx-2">Are you a current student?</p>
                <!-- Div with form-check class for Bootstrap styling -->
                <div class="form-check">
                    <!-- Radio input button for yes -->
                    <input class="form-check-input" type="radio" id="current-yes" value="yes" name="current-student" checked>
                    <!-- Label for yes -->
                    <label class="form-check-label" for="current-yes">Yes</label>
                </div>
                <!-- Div with form-check class for Bootstrap styling -->
                <div class="form-check">
                    <!-- Radio input button for no -->
                    <input class="form-check-input" type="radio" id="current-no" value="no" name="current-student">
                    <!-- Label for no -->
                    <label class="form-check-label" for="current-no">No</label>
                </div>
                <br>
                <!-- Submit button -->
                <input class="btn btn-primary" type="submit">
                <!-- End of form wrapper -->
            </form> <!-- End of form wrapper -->
        </div> <!-- End of Form div -->
    </div> <!-- End of row div -->
    <br>
        {{!-- Simple link back to '/' home page --}}
        <p><a href="/">Back to Home Page</a></p>